# Replit Configuration
# This file tells Replit how to run your app

run = "npm start"
entrypoint = "server.js"

[env]
# Environment variables
NODE_ENV = "production"

[interpreter]
command = [
    "prybar-nodejs",
    "--ps1",
    "\u0001\u001b[33m\u0002\u0001\u001b[00m\u0002 ",
    "-i"
]

[packager]
language = "nodejs"

[packager.features]
packageSearch = true
guessImports = true

[nix]
channel = "unstable"
